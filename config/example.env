# ========= Core =========
SERVICE_USER=aiops
REPO_BASE_DIR=/srv/ai/repos

# ========= Ollama / Aider =========
OLLAMA_HOST=http://127.0.0.1:11434
SMALL_MODEL=qwen2.5-coder:1.5b
MAIN_MODEL=qwen2.5-coder:14b
MODEL=qwen2.5-coder:1.5b

# ========= GitHub =========
GITHUB_TOKEN=ghp_replace_me
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo
REPO_URL=https://github.com/your-org-or-user/your-repo.git
DEFAULT_BASE_BRANCH=main
BRANCH_PREFIX=ai/issue
COMMIT_AUTHOR_NAME=aiops-bot
COMMIT_AUTHOR_EMAIL=aiops-bot@example.com
PR_LABELS=ai-generated

# ========= n8n =========
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678
N8N_ENCRYPTION_KEY=replace_with_long_random_string
GENERIC_TIMEZONE=UTC

# Basic auth for n8n UI (recommended)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

# Log retention / pruning
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=1000

# ========= Workflow behavior =========
TEST_CMD=pytest -q
ISSUE_NUMBER=1
